# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must never be committed. Each fresh worktree copies `.env` from the primary
# checkout (see `bun run worktree-setup`), so you only fill this in once.
#
# `.env.local` (Convex deployment URL/slug) is NOT listed here — it is created
# automatically by `bun run dev` on first login.

# --- Scaleway (Apple-silicon fleet host provisioning) ---
SCALEWAY_ACCESS_KEY_ID=SCWXXXXXXXXXXXXXXXXX
SCALEWAY_SECRET_KEY=00000000-0000-0000-0000-000000000000

# --- Anthropic API (orchestrator Opus tool loop) ---
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key

# --- GitHub PAT (ghcr golden-image pulls, repo automation) ---
GITHUB_PAT=ghp_your_github_personal_access_token

# --- Slack app (signing secret + bot token from the app's "OAuth & Permissions" / "Basic Information") ---
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# --- Tailscale (host + ephemeral-VM tailnet enrollment, API access) ---
# Generate auth keys in the Tailscale admin console (Settings -> Keys).
TAILSCALE_AUTHKEY=tskey-auth-your-tailscale-auth-key
TAILSCALE_API_KEY=tskey-api-your-tailscale-api-key

# --- Claude Code OAuth token (the agent running inside devbox VMs) ---
# From `claude setup-token`.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-your-claude-code-oauth-token

# --- Internal shared secrets (you generate these — any random hex string) ---
# e.g. `openssl rand -hex 24`
DEVBOX_SHARED_SECRET=generate_with_openssl_rand_hex_24
DASHBOARD_SECRET=generate_with_openssl_rand_hex_24

# --- Tailscale ephemeral auth key (short-lived devbox VMs; "Ephemeral" + "Reusable" in the admin console) ---
TAILSCALE_EPHEMERAL_AUTHKEY=tskey-auth-your-tailscale-ephemeral-auth-key
