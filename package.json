{
  "name": "teammate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "convex dev",
    "validate": "concurrently --group --prefix-colors auto --names typecheck,lint,test \"bun run typecheck\" \"bun run lint\" \"bun run test\"",
    "typecheck": "tsc --noEmit && tsc -p convex --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test"
  },
  "dependencies": {
    "convex": "1.41.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "1.3.14",
    "concurrently": "10.0.3",
    "typescript": "6.0.3"
  },
  "workspaces": [
    "gateway",
    "web"
  ]
}
